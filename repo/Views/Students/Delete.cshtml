@model repo.Models.Student
@{
    ViewData["Title"] = "Удаление студента";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-danger text-white">
            <h4><i class="fas fa-exclamation-triangle"></i> Удаление студента</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <strong>Внимание!</strong> Вы действительно хотите удалить следующего студента?
            </div>

            <table class="table table-bordered">
                <tr>
                    <th style="width: 30%">Номер зачетки:</th>
                    <td>@Model.RecordBookNumber</td>
                </tr>
                <tr>
                    <th>ФИО:</th>
                    <td>@Model.LastName @Model.FirstName </td>
                </tr>
                <tr>
                    <th>Тип студента:</th>
                    <td>
                        @if (Model.StudentType == "FullTime")
                        {
                            <span class="badge bg-primary">Очник</span>
                        }
                        else if (Model.StudentType == "PartTime")
                        {
                            <span class="badge bg-warning">Заочник</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Целевик</span>
                        }
                    </td>
                </tr>
                <tr>
                    <th>Группа:</th>
                    <td>@(Model.Group?.Name ?? "-")</td>
                </tr>
                <tr>
                    <th>Email:</th>
                    <td>@Model.Email</td>
                </tr>
            </table>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="RecordBookNumber" />
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Удалить
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Отмена
                </a>
            </form>
        </div>
    </div>
</div>