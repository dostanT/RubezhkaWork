<!-- В самом верху замени получение типа -->
@model StudentEditViewModel
@{
    ViewData["Title"] = "Редактирование студента";
}

<!-- В форме измени hidden поле -->
<input type="hidden" asp-for="Id" />
<!-- Удали строку с input для StudentType (она readonly disabled) -->

<!-- В JavaScript в конце замени -->
@section Scripts {
    <script>
        function showFields() {
            var type = '@Model.StudentType';
            // ... остальное без изменений
        }

        function addDiscipline() {
            var disciplineId = document.getElementById('DisciplineSelect').value;
            var grade = prompt('Введите оценку (2, 3, 4, 5, зачет):', '5');
            if (disciplineId && grade) {
                // Создаем форму с оценкой
                var form = document.createElement('form');
                form.method = 'post';
                form.action = '@Url.Action("AssignDiscipline", "Students")';
                
                var studentIdInput = document.createElement('input');
                studentIdInput.type = 'hidden';
                studentIdInput.name = 'studentId';
                studentIdInput.value = '@Model.Id';
                
                var disciplineIdInput = document.createElement('input');
                disciplineIdInput.type = 'hidden';
                disciplineIdInput.name = 'disciplineId';
                disciplineIdInput.value = disciplineId;
                
                var gradeInput = document.createElement('input');
                gradeInput.type = 'hidden';
                gradeInput.name = 'grade';
                gradeInput.value = grade;
                
                form.appendChild(studentIdInput);
                form.appendChild(disciplineIdInput);
                form.appendChild(gradeInput);
                document.body.appendChild(form);
                form.submit();
            } else if (!disciplineId) {
                alert('Выберите дисциплину');
            }
        }

        // Исправь удаление
        function removeDiscipline(disciplineId) {
            if (confirm('Удалить дисциплину?')) {
                var form = document.createElement('form');
                form.method = 'post';
                form.action = '@Url.Action("RemoveDiscipline", "Students")';
                
                var studentIdInput = document.createElement('input');
                studentIdInput.type = 'hidden';
                studentIdInput.name = 'studentId';
                studentIdInput.value = '@Model.Id';
                
                var disciplineIdInput = document.createElement('input');
                disciplineIdInput.type = 'hidden';
                disciplineIdInput.name = 'disciplineId';
                disciplineIdInput.value = disciplineId;
                
                form.appendChild(studentIdInput);
                form.appendChild(disciplineIdInput);
                document.body.appendChild(form);
                form.submit();
            }
        }

        showFields();
    </script>
}