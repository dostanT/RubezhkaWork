@model StudentEditViewModel
@{
    ViewData["Title"] = "Редактирование студента";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-warning text-white">
            <h4><i class="fas fa-edit"></i> Редактирование студента</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="RecordBookNumber" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="RecordBookNumber" class="form-label">Номер зачетки</label>
                            <input asp-for="RecordBookNumber" class="form-control" readonly disabled />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="LastName" class="form-label">Фамилия *</label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="FirstName" class="form-label">Имя *</label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="Patronymic" class="form-label">Отчество</label>
                            <input asp-for="Patronymic" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="DateOfBirth" class="form-label">Дата рождения *</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control" />
                            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="StudentType" class="form-label">Тип студента</label>
                            <input asp-for="StudentType" class="form-control" readonly disabled />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Email" class="form-label">Email *</label>
                            <input asp-for="Email" type="email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Phone" class="form-label">Телефон *</label>
                            <input asp-for="Phone" class="form-control" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Address" class="form-label">Адрес</label>
                    <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="GroupId" class="form-label">Группа</label>
                            <select asp-for="GroupId" class="form-select" asp-items="@(ViewBag.Groups as SelectList)">
                                <option value="">Выберите группу...</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="DepartmentId" class="form-label">Кафедра</label>
                            <select asp-for="DepartmentId" class="form-select" asp-items="@(ViewBag.Departments as SelectList)">
                                <option value="">Выберите кафедру...</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- FullTime поля -->
                <div id="FullTimeFields" style="display: none;">
                    <div class="card mb-3 border-primary">
                        <div class="card-header bg-primary text-white">
                            <h6 class="mb-0">Данные для очного обучения</h6>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group mb-3">
                                        <label asp-for="EgeScore" class="form-label">Балл ЕГЭ</label>
                                        <input asp-for="EgeScore" type="number" class="form-control" min="0" max="100" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group mb-3">
                                        <label asp-for="AverageScore" class="form-label">Средний балл</label>
                                        <input asp-for="AverageScore" type="number" step="0.01" class="form-control" min="0" max="5" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- PartTime поля -->
                <div id="PartTimeFields" style="display: none;">
                    <div class="card mb-3 border-warning">
                        <div class="card-header bg-warning text-white">
                            <h6 class="mb-0">Данные для заочного обучения</h6>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group mb-3">
                                        <label asp-for="WorkPlace" class="form-label">Место работы</label>
                                        <input asp-for="WorkPlace" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group mb-3">
                                        <label asp-for="Position" class="form-label">Должность</label>
                                        <input asp-for="Position" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group mb-3">
                                        <label asp-for="TuitionFee" class="form-label">Стоимость обучения</label>
                                        <input asp-for="TuitionFee" type="number" step="0.01" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Target поля -->
                <div id="TargetFields" style="display: none;">
                    <div class="card mb-3 border-danger">
                        <div class="card-header bg-danger text-white">
                            <h6 class="mb-0">Данные для целевого обучения</h6>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group mb-3">
                                        <label asp-for="TargetCompany" class="form-label">Целевая компания</label>
                                        <input asp-for="TargetCompany" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group mb-3">
                                        <label asp-for="TuitionFee" class="form-label">Стоимость обучения</label>
                                        <input asp-for="TuitionFee" type="number" step="0.01" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Дисциплины -->
                <div class="card mb-3">
                    <div class="card-header bg-info text-white">
                        <h6 class="mb-0"><i class="fas fa-book"></i> Дисциплины студента</h6>
                    </div>
                    <div class="card-body">
                        @if (ViewBag.StudentDisciplines != null && ViewBag.StudentDisciplines.Count > 0)
                        {
                            <ul class="list-group mb-3">
                                @foreach (var discipline in ViewBag.StudentDisciplines)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        @discipline.Name
                                        <form asp-action="RemoveDiscipline" method="post" style="display: inline;">
                                            <input type="hidden" name="studentId" value="@Model.RecordBookNumber" />
                                            <input type="hidden" name="disciplineId" value="@discipline.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Удалить дисциплину?')">
                                                <i class="fas fa-trash"></i> Удалить
                                            </button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted">Нет добавленных дисциплин</p>
                        }

                        <div class="row">
                            <div class="col-md-8">
                                <select id="DisciplineSelect" class="form-select">
                                    <option value="">Выберите дисциплину...</option>
                                    @foreach (var discipline in ViewBag.Disciplines)
                                    {
                                        <option value="@discipline.Id">@discipline.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <button type="button" class="btn btn-primary" onclick="addDiscipline()">
                                    <i class="fas fa-plus"></i> Добавить
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-warning">
                        <i class="fas fa-save"></i> Сохранить
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Отмена
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<form id="addDisciplineForm" asp-action="AssignDiscipline" method="post" style="display: none;">
    <input type="hidden" name="studentId" value="@Model.RecordBookNumber" />
    <input type="hidden" name="disciplineId" id="disciplineIdInput" />
</form>

@section Scripts {
    <script>
        function showFields() {
            var type = '@Model.StudentType';
            document.getElementById('FullTimeFields').style.display = 'none';
            document.getElementById('PartTimeFields').style.display = 'none';
            document.getElementById('TargetFields').style.display = 'none';

            if (type === 'FullTime') {
                document.getElementById('FullTimeFields').style.display = 'block';
            } else if (type === 'PartTime') {
                document.getElementById('PartTimeFields').style.display = 'block';
            } else if (type === 'Target') {
                document.getElementById('TargetFields').style.display = 'block';
            }
        }

        function addDiscipline() {
            var disciplineId = document.getElementById('DisciplineSelect').value;
            if (disciplineId) {
                document.getElementById('disciplineIdInput').value = disciplineId;
                document.getElementById('addDisciplineForm').submit();
            } else {
                alert('Выберите дисциплину');
            }
        }

        showFields();
    </script>
}