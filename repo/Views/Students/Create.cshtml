@model repo.Models.Student
@{
    ViewData["Title"] = "Добавление студента";
}

<div class="fade-in">
    <div class="card">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="fas fa-user-plus"></i> Добавление нового студента</h5>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="RecordBookNumber" class="form-label"></label>
                            <input asp-for="RecordBookNumber" class="form-control" placeholder="Введите номер зачетной книжки" />
                            <span asp-validation-for="RecordBookNumber" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="LastName" class="form-label"></label>
                            <input asp-for="LastName" class="form-control" placeholder="Введите фамилию" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="FirstName" class="form-label"></label>
                            <input asp-for="FirstName" class="form-control" placeholder="Введите имя" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Patronymic" class="form-label"></label>
                            <input asp-for="Patronymic" class="form-control" placeholder="Введите отчество" />
                            <span asp-validation-for="Patronymic" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Выбор типа студента -->
                <div class="form-group">
                    <label for="StudentType">Тип студента</label>
                    <select id="StudentType" class="form-select">
                        <option value="">Выберите тип...</option>
                        <option value="FullTime">Очный</option>
                        <option value="PartTime">Заочный</option>
                        <option value="Target">Целевой</option>
                    </select>
                </div>
                <div class="form-group mt-3">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Сохранить
                    </button>
                    <a href="@Url.Action("Index", "Students")" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Отмена
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('StudentType').addEventListener('change', function() {
            document.getElementById('FullTimeFields').style.display = 'none';
            document.getElementById('PartTimeFields').style.display = 'none';
            document.getElementById('TargetFields').style.display = 'none';

            if (this.value === 'FullTime') {
                document.getElementById('FullTimeFields').style.display = 'block';
            } else if (this.value === 'PartTime') {
                document.getElementById('PartTimeFields').style.display = 'block';
            } else if (this.value === 'Target') {
                document.getElementById('TargetFields').style.display = 'block';
            }
        });
    </script>
}