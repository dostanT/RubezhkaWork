@model IEnumerable<repo.Models.Student>
@{
    ViewData["Title"] = "Фильтрация студентов";
}

<div class="container mt-4">
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h4><i class="fas fa-filter"></i> Фильтрация студентов</h4>
        </div>
        <div class="card-body">
            <form asp-action="Filter" method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Группа</label>
                    <select name="groupName" class="form-select">
                        <option value="">Все группы</option>
                        @foreach (var group in ViewBag.Groups)
                        {
                            <option value="@group.Name">@group.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Дисциплина</label>
                    <select name="disciplineName" class="form-select">
                        <option value="">Все дисциплины</option>
                        @foreach (var discipline in ViewBag.Disciplines)
                        {
                            <option value="@discipline.Name">@discipline.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Преподаватель</label>
                    <select name="teacherLastName" class="form-select">
                        <option value="">Все преподаватели</option>
                        @foreach (var teacher in ViewBag.Teachers)
                        {
                            <option value="@teacher.LastName">@teacher.FullName</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search"></i> Применить фильтр
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ViewBag.FilterType))
    {
        <div class="alert alert-info">
            <strong>Фильтр по @ViewBag.FilterType:</strong> @ViewBag.FilterValue
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>№ зачетки</th>
                            <th>Фамилия</th>
                            <th>Имя</th>
                            <th>Тип</th>
                            <th>Группа</th>
                            <th>Email</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in Model)
                        {
                            <tr>
                                <td>@student.RecordBookNumber</td>
                                <td>@student.LastName</td>
                                <td>@student.FirstName</td>
                                <td>
                                    @if (student.StudentType == "FullTime")
                                    {
                                        <span class="badge bg-primary">Очник</span>
                                    }
                                    else if (student.StudentType == "PartTime")
                                    {
                                        <span class="badge bg-warning">Заочник</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Целевик</span>
                                    }
                                </td>
                                <td>@(student.Group?.Name ?? "-")</td>
                                <td>@student.Email</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@student.RecordBookNumber" class="btn btn-sm btn-info">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@student.RecordBookNumber" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-warning text-center">
                    <i class="fas fa-info-circle"></i> Студенты не найдены
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Назад к списку
        </a>
    </div>
</div>