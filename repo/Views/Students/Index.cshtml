@model IEnumerable<repo.Models.Student>
@{
    ViewData["Title"] = "Список студентов";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="fas fa-users"></i> Список студентов</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus"></i> Добавить студента
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>№ зачетки</th>
                            <th>Фамилия</th>
                            <th>Имя</th>
                            <th>Тип</th>
                            <th>Группа</th>
                            <th>Кафедра</th>
                            <th>Email</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in Model)
                        {
                            <tr>
                                <td>@student.RecordBookNumber</td>
                                <td>@student.LastName</td>
                                <td>@student.FirstName</td>
                                <td>
                                    @if (student.StudentType == "FullTime")
                                    {
                                        <span class="badge bg-primary">Очник</span>
                                    }
                                    else if (student.StudentType == "PartTime")
                                    {
                                        <span class="badge bg-warning">Заочник</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Целевик</span>
                                    }
                                </td>
                                <td>@(student.Group?.Name ?? "-")</td>
                                <td>@(student.Department?.Name ?? "-")</td>
                                <td>@student.Email</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@student.RecordBookNumber" class="btn btn-sm btn-info">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@student.RecordBookNumber" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@student.RecordBookNumber" class="btn btn-sm btn-danger">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>