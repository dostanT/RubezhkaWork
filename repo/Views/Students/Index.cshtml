@model List<repo.Models.Student>
@{
    ViewData["Title"] = "Студенты";
}

<div class="fade-in">
    <div class="card">
        <div class="card-header bg-primary text-white d-flex justify-between align-center">
            <h5 class="mb-0"><i class="fas fa-user-graduate"></i> Список студентов</h5>
            <a href="@Url.Action("Create", "Students")" class="btn btn-success btn-sm">
                <i class="fas fa-plus"></i> Добавить студента
            </a>
        </div>
        <div class="card-body">
            <!-- Фильтры -->
            <div class="filter-section mb-4">
                <div class="filter-title">
                    <i class="fas fa-filter"></i> Быстрая фильтрация
                </div>
                <div class="filter-buttons">
                    <a href="@Url.Action("Filter", "Students")" class="btn btn-sm btn-info">
                        <i class="fas fa-list"></i> Все
                    </a>
                    <a href="@Url.Action("Filter", "Students", new { groupName = "Группа 1" })" class="btn btn-sm btn-primary">
                        <i class="fas fa-users"></i> По группам
                    </a>
                    <a href="@Url.Action("Filter", "Students", new { departmentName = "Кафедра" })" class="btn btn-sm btn-success">
                        <i class="fas fa-building"></i> По кафедрам
                    </a>
                    <a href="@Url.Action("Filter", "Students", new { disciplineName = "Дисциплина" })" class="btn btn-sm btn-warning">
                        <i class="fas fa-book"></i> По дисциплинам
                    </a>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>№ зачетки</th>
                            <th>ФИО</th>
                            <th>Группа</th>
                            <th>Кафедра</th>
                            <th>Тип обучения</th>
                            <th>Дисциплин</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var student in Model)
                            {
                                <tr>
                                    <td>@student.RecordBookNumber</td>
                                    <td>@student.LastName @student.FirstName</td>
                                    <td>@(student.Group?.Name ?? "—")</td>
                                    <td>@(student.Department?.Name ?? "—")</td>
                                    <td>
                                        @if (student is repo.Models.FullTimeStudent)
                                        {
                                            <span class="badge bg-primary">Очное</span>
                                        }
                                        else if (student is repo.Models.PartTimeStudent)
                                        {
                                            <span class="badge bg-info">Заочное</span>
                                        }
                                        else if (student is repo.Models.TargetStudent)
                                        {
                                            <span class="badge bg-success">Целевое</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">—</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@(student.Disciplines?.Count ?? 0)</span>
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Details", "Students", new { id = student.RecordBookNumber })" 
                                           class="btn btn-sm btn-info" title="Подробнее">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", "Students", new { id = student.RecordBookNumber })" 
                                           class="btn btn-sm btn-warning" title="Редактировать">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a href="@Url.Action("Delete", "Students", new { id = student.RecordBookNumber })" 
                                           class="btn btn-sm btn-danger" title="Удалить">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center">
                                    <div class="alert alert-info mb-0">
                                        <i class="fas fa-info-circle"></i> Нет данных о студентах
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>