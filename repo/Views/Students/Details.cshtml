@model repo.Models.Student
@{
    ViewData["Title"] = "Детали студента";
}

<div class="fade-in">
    <div class="card">
        <div class="card-header bg-info text-white d-flex justify-between align-center">
            <h5 class="mb-0"><i class="fas fa-user-graduate"></i> Информация о студенте</h5>
            <div>
                <a href="@Url.Action("Edit", "Students", new { id = Model.RecordBookNumber })" class="btn btn-warning btn-sm">
                    <i class="fas fa-edit"></i> Редактировать
                </a>
                <a href="@Url.Action("Index", "Students")" class="btn btn-secondary btn-sm">
                    <i class="fas fa-arrow-left"></i> Назад
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <table class="table table-bordered">
                        <tr>
                            <th style="width: 40%;">Номер зачетной книжки:</th>
                            <td>@Model.RecordBookNumber</td>
                        </tr>
                        <tr>
                            <th>Фамилия:</th>
                            <td>@Model.LastName</td>
                        </tr>
                        <tr>
                            <th>Имя:</th>
                            <td>@Model.FirstName</td>
                        </tr>
                        <tr>
                            <th>Отчество:</th>
                            <td>@Model.Patronymic</td>
                        </tr>
                        <tr>
                            <th>Группа:</th>
                            <td>@(Model.Group?.Name ?? "Не назначена")</td>
                        </tr>
                        <tr>
                            <th>Кафедра:</th>
                            <td>@(Model.Department?.Name ?? "Не назначена")</td>
                        </tr>
                        <tr>
                            <th>Тип обучения:</th>
                            <td>
                                @if (Model is repo.Models.FullTimeStudent)
                                {
                                    <span class="badge bg-primary">Очное</span>
                                }
                                else if (Model is repo.Models.PartTimeStudent)
                                {
                                    <span class="badge bg-info">Заочное</span>
                                }
                                else if (Model is repo.Models.TargetStudent)
                                {
                                    <span class="badge bg-success">Целевое</span>
                                }
                            </td>
                        </tr>

                        @* Поля для конкретного типа студента *@
                        @if (Model is repo.Models.FullTimeStudent fullTime)
                        {
                            <tr>
                                <th>Средний балл:</th>
                                <td>@fullTime.AverageScore.ToString("F2")</td>
                            </tr>
                            <tr>
                                <th>ЕГЭ:</th>
                                <td>@fullTime.EgeScore</td>
                            </tr>
                        }
                        @if (Model is repo.Models.PartTimeStudent partTime)
                        {
                            <tr>
                                <th>Место работы:</th>
                                <td>@partTime.WorkPlace</td>
                            </tr>
                            <tr>
                                <th>Должность:</th>
                                <td>@partTime.Position</td>
                            </tr>
                            <tr>
                                <th>Сумма обучения:</th>
                                <td>@partTime.TuitionFee.ToString("C")</td>
                            </tr>
                        }
                        @if (Model is repo.Models.TargetStudent target)
                        {
                            <tr>
                                <th>Компания:</th>
                                <td>@target.TargetCompany</td>
                            </tr>
                            <tr>
                                <th>Сумма обучения:</th>
                                <td>@target.TuitionFee.ToString("C")</td>
                            </tr>
                        }
                    </table>
                </div>

                <div class="col-md-6">
                    <h5>Дисциплины</h5>
                    @if (Model.Disciplines != null && Model.Disciplines.Any())
                    {
                        <table class="table table-striped table-bordered mt-2">
                            <thead>
                                <tr>
                                    <th>Название</th>
                                    <th>Оценка</th>
                                    <th>Преподаватель</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in Model.Disciplines)
                                {
                                    <tr>
                                        <td>@d.Name</td>
                                        <td>@(d.Grade ?? "—")</td>
                                        <td>@(d.Teacher?.FullName ?? "Не назначен")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="alert alert-info mt-3">
                            <i class="fas fa-info-circle"></i> Студент не изучает ни одной дисциплины
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>