@model repo.Models.Student
@{
    ViewData["Title"] = "Детали студента";
    var studentType = Model.GetType().Name.Replace("Student", "");
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-info text-white">
            <h4><i class="fas fa-user"></i> Детали студента</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <table class="table table-bordered">
                        <tr>
                            <th style="width: 40%">Номер зачетки:</th>
                            <td>@Model.RecordBookNumber</td>
                        </tr>
                        <tr>
                            <th>Фамилия:</th>
                            <td>@Model.LastName</td>
                        </tr>
                        <tr>
                            <th>Имя:</th>
                            <td>@Model.FirstName</td>
                        </tr>
                        <tr>
                            <th>Отчество:</th>
                            <td>@(Model.Patronymic ?? "-")</td>
                        </tr>
                        <tr>
                            <th>Дата рождения:</th>
                            <td>@Model.DateOfBirth.ToString("dd.MM.yyyy")</td>
                        </tr>
                        <tr>
                            <th>Тип студента:</th>
                            <td>
                                @if (studentType == "FullTime")
                                {
                                    <span class="badge bg-primary">Очник</span>
                                }
                                else if (studentType == "PartTime")
                                {
                                    <span class="badge bg-warning">Заочник</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Целевик</span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-md-6">
                    <table class="table table-bordered">
                        <tr>
                            <th style="width: 40%">Email:</th>
                            <td>@Model.Email</td>
                        </tr>
                        <tr>
                            <th>Телефон:</th>
                            <td>@Model.Phone</td>
                        </tr>
                        <tr>
                            <th>Адрес:</th>
                            <td>@(Model.Address ?? "-")</td>
                        </tr>
                        <tr>
                            <th>Группа:</th>
                            <td>@(Model.Group?.Name ?? "-")</td>
                        </tr>
                        <tr>
                            <th>Кафедра:</th>
                            <td>@(Model.Department?.Name ?? "-")</td>
                        </tr>
                    </table>
                </div>
            </div>

            @if (Model is FullTimeStudent fullTime)
            {
                <div class="alert alert-primary mt-3">
                    <h5><i class="fas fa-graduation-cap"></i> Данные очного обучения:</h5>
                    <p><strong>Балл ЕГЭ:</strong> @fullTime.EgeScore</p>
                    <p><strong>Средний балл:</strong> @fullTime.AverageScore.ToString("F2")</p>
                </div>
            }
            else if (Model is PartTimeStudent partTime)
            {
                <div class="alert alert-warning mt-3">
                    <h5><i class="fas fa-briefcase"></i> Данные заочного обучения:</h5>
                    <p><strong>Место работы:</strong> @partTime.WorkPlace</p>
                    <p><strong>Должность:</strong> @partTime.Position</p>
                    <p><strong>Стоимость обучения:</strong> @partTime.TuitionFee.ToString("C")</p>
                </div>
            }
            else if (Model is TargetStudent target)
            {
                <div class="alert alert-danger mt-3">
                    <h5><i class="fas fa-building"></i> Данные целевого обучения:</h5>
                    <p><strong>Целевая компания:</strong> @target.TargetCompany</p>
                    <p><strong>Стоимость обучения:</strong> @target.TuitionFee.ToString("C")</p>
                </div>
            }

            @if (Model.StudentDisciplines != null && Model.StudentDisciplines.Any())
            {
                <div class="mt-3">
                    <h5><i class="fas fa-book"></i> Дисциплины и оценки:</h5>
                    <ul class="list-group">
                        @foreach (var sd in Model.StudentDisciplines)
                        {
                            <li class="list-group-item">
                                <strong>@sd.Discipline.Name</strong>
                                @if (sd.Discipline.Teacher != null)
                                {
                                    <span class="text-muted"> - Преподаватель: @sd.Discipline.Teacher.FullName</span>
                                }
                                <span class="badge bg-success float-end">Оценка: @sd.Grade</span>
                            </li>
                        }
                    </ul>
                </div>
            }

            <div class="mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="fas fa-edit"></i> Редактировать
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Назад
                </a>
            </div>
        </div>
    </div>
</div>