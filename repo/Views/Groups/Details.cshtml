@model repo.Models.Group
@{
    ViewData["Title"] = $"Группа: {Model?.Name}";
    var students = ViewBag.Students as List<repo.Models.Student>;
}

<div class="fade-in">
    <div class="d-flex justify-between align-center mb-3">
        <h2><i class="fas fa-users"></i> Группа: @Model?.Name</h2>
        <div>
            <a href="@Url.Action("Edit", new { id = Model?.Id })" class="btn btn-warning">
                <i class="fas fa-edit"></i> Редактировать
            </a>
            <a href="@Url.Action("Index")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Назад
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle"></i> Информация о группе</h5>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <strong>ID группы:</strong> @Model?.Id
                    </div>
                    <div class="mb-2">
                        <strong>Название группы:</strong> @Model?.Name
                    </div>
                    <div class="mb-2">
                        <strong>Количество студентов:</strong> 
                        <span class="badge bg-success">@(students?.Count ?? 0) чел.</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8 mb-4">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-user-graduate"></i> Студенты группы</h5>
                </div>
                <div class="card-body">
                    @if (students != null && students.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>№ зачетки</th>
                                        <th>ФИО</th>
                                        <th>Кафедра</th>
                                        <th>Тип обучения</th>
                                        <th>Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var student in students)
                                    {
                                        <tr>
                                            <td>@student.RecordBookNumber</td>
                                            <td>@student.LastName @student.FirstName @student.Patronymic</td>
                                            <td>@(student.Department?.Name ?? "—")</td>
                                            <td>
                                                @if (student is FullTimeStudent)
                                                {
                                                    <span class="badge bg-primary">Очное</span>
                                                }
                                                else if (student is PartTimeStudent)
                                                {
                                                    <span class="badge bg-info">Заочное</span>
                                                }
                                                else if (student is TargetStudent)
                                                {
                                                    <span class="badge bg-success">Целевое</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">—</span>
                                                }
                                            </td>
                                            <td>
                                                <a href="@Url.Action("Details", "Students", new { id = student.RecordBookNumber })" 
                                                   class="btn btn-sm btn-info">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning text-center">
                            <i class="fas fa-exclamation-triangle"></i> 
                            В данной группе нет студентов.
                            <a href="@Url.Action("Index", "Students")" class="alert-link">Добавить студентов</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>