@model repo.Models.Group
@{
    ViewData["Title"] = "Детали группы";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-info text-white">
            <h4><i class="fas fa-users"></i> Детали группы</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <table class="table table-bordered">
                        <tr>
                            <th style="width: 40%">ID:</th>
                            <td>@Model.Id</td>
                        </tr>
                        <tr>
                            <th>Название группы:</th>
                            <td>@Model.Name</td>
                        </tr>
                        <tr>
                            <th>Курс:</th>
                            <td>
                                <span class="badge bg-primary">@Model.YearOfStudy курс</span>
                            </td>
                        </tr>
                        <tr>
                            <th>Количество студентов:</th>
                            <td>
                                <span class="badge bg-success">@ViewBag.StudentsCount</span>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            @if (ViewBag.Students != null && ViewBag.Students.Count > 0)
            {
                <div class="mt-4">
                    <h5><i class="fas fa-user-graduate"></i> Студенты группы</h5>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>№ зачетки</th>
                                    <th>Фамилия</th>
                                    <th>Имя</th>
                                    <th>Отчество</th>
                                    <th>Тип</th>
                                    <th>Email</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var student in ViewBag.Students)
                                {
                                    <tr>
                                        <td>@student.RecordBookNumber</td>
                                        <td>@student.LastName</td>
                                        <td>@student.FirstName</td>
                                        <td>@student.Patronymic</td>
                                        <td>
                                            @if (student.StudentType == "FullTime")
                                            {
                                                <span class="badge bg-primary">Очник</span>
                                            }
                                            else if (student.StudentType == "PartTime")
                                            {
                                                <span class="badge bg-warning">Заочник</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Целевик</span>
                                            }
                                        </td>
                                        <td>@student.Email</td>
                                        <td>
                                            <a asp-controller="Students" asp-action="Details" asp-route-id="@student.RecordBookNumber" class="btn btn-sm btn-info">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-controller="Students" asp-action="Edit" asp-route-id="@student.RecordBookNumber" class="btn btn-sm btn-warning">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info mt-3">
                    <i class="fas fa-info-circle"></i> В группе нет студентов
                </div>
            }

            <div class="mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="fas fa-edit"></i> Редактировать
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Назад
                </a>
            </div>
        </div>
    </div>
</div>