@model repo.Models.Group
@{
    ViewData["Title"] = "Создание группы";
}

<div class="fade-in">
    <div class="d-flex justify-between align-center mb-3">
        <h2><i class="fas fa-plus-circle"></i> Создание новой группы</h2>
        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Назад
        </a>
    </div>

    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-info-circle"></i> Заполните информацию о группе</h5>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Name" class="form-label">
                                <i class="fas fa-tag"></i> Название группы <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Name" class="form-control" placeholder="Пример: ИС-21, ПИ-31, БИ-41" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                            <small class="text-muted">Введите уникальное название группы</small>
                        </div>
                    </div>
                </div>

                <div class="alert alert-info mt-3">
                    <i class="fas fa-info-circle"></i> 
                    После создания группы вы сможете добавлять в нее студентов через редактирование профиля студента.
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Создать группу
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Отмена
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}