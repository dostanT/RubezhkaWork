@model repo.Models.Group
@{
    ViewData["Title"] = "Удаление группы";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-danger text-white">
            <h4><i class="fas fa-exclamation-triangle"></i> Удаление группы</h4>
        </div>
        <div class="card-body">
            @if (ViewBag.HasStudents == true)
            {
                <div class="alert alert-danger">
                    <h5><i class="fas fa-ban"></i> Невозможно удалить группу!</h5>
                    <p>В группе <strong>@Model.Name</strong> числится <strong>@ViewBag.StudentsCount</strong> студентов.</p>
                    <p>Перед удалением группы необходимо перевести или отчислить всех студентов.</p>
                    
                    <div class="mt-3">
                        <h6>Список студентов:</h6>
                        <ul class="list-group">
                            @foreach (var student in ViewBag.Students)
                            {
                                <li class="list-group-item">
                                    @student.LastName @student.FirstName @student.Patronymic
                                    <span class="badge bg-secondary">@student.RecordBookNumber</span>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
                
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Назад к списку
                </a>
            }
            else
            {
                <div class="alert alert-warning">
                    <strong>Внимание!</strong> Вы действительно хотите удалить группу?
                </div>

                <table class="table table-bordered">
                    <tr>
                        <th style="width: 30%">ID:</th>
                        <td>@Model.Id</td>
                    </tr>
                    <tr>
                        <th>Название группы:</th>
                        <td>@Model.Name</td>
                    </tr>
                    <tr>
                        <th>Курс:</th>
                        <td>@Model.YearOfStudy</td>
                    </tr>
                </table>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Удалить
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Отмена
                    </a>
                </form>
            }
        </div>
    </div>
</div>