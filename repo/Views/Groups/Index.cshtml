@model IEnumerable<repo.Models.Group>
@{
    ViewData["Title"] = "Группы";
}

<div class="fade-in">
    <div class="d-flex justify-between align-center mb-3">
        <h2><i class="fas fa-users"></i> Управление группами</h2>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-plus-circle"></i> Создать группу
        </a>
    </div>

    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-list"></i> Список групп</h5>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Название группы</th>
                                <th>Год обучения</th>
                                <th>Кол-во студентов</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var group in Model)
                            {
                                <tr>
                                    <td>@group.Id</td>
                                    <td>
                                        <i class="fas fa-users"></i> 
                                        <strong>@group.Name</strong>
                                    </td>
                                    <td>
                                        <span class="badge @(group.Students?.Count > 0 ? "bg-success" : "bg-secondary")">
                                            @(group.Students?.Count ?? 0) студентов
                                        </span>
                                    </td>
                                    <td>
                                        <div class="btn-group">
                                            <a href="@Url.Action("Details", new { id = group.Id })" 
                                               class="btn btn-sm btn-info" title="Подробнее">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="@Url.Action("Edit", new { id = group.Id })" 
                                               class="btn btn-sm btn-warning" title="Редактировать">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="@Url.Action("Delete", new { id = group.Id })" 
                                               class="btn btn-sm btn-danger" title="Удалить">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle"></i> Группы не найдены.
                    <a href="@Url.Action("Create")" class="alert-link">Создать первую группу</a>
                </div>
            }
        </div>
    </div>
</div>