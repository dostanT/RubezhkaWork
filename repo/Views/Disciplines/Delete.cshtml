@model repo.Models.Discipline
@{
    ViewData["Title"] = "Удаление дисциплины";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-danger text-white">
            <h4><i class="fas fa-exclamation-triangle"></i> Удаление дисциплины</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <strong>Внимание!</strong> Вы действительно хотите удалить дисциплину?
            </div>

            <table class="table table-bordered">
                <tr>
                    <th style="width: 30%">ID:</th>
                    <td>@Model.Id</td>
                </tr>
                <tr>
                    <th>Название:</th>
                    <td>@Model.Name</td>
                </tr>
                <tr>
                    <th>Кредиты:</th>
                    <td>@Model.Credits</td>
                </tr>
                <tr>
                    <th>Преподаватель:</th>
                    <td>@(Model.Teacher?.FullName ?? "Не назначен")</td>
                </tr>
                <tr>
                    <th>Описание:</th>
                    <td>@(string.IsNullOrEmpty(Model.Description) ? "Нет описания" : Model.Description)</td>
                </tr>
            </table>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Удалить
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Отмена
                </a>
            </form>
        </div>
    </div>
</div>