@model IEnumerable<repo.Models.Discipline>

@{
    ViewData["Title"] = "Дисциплины";
}

<div class="fade-in">
    <div class="d-flex justify-between align-center mb-3">
        <h2><i class="fas fa-book"></i> Дисциплины</h2>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-plus"></i> Добавить дисциплину
        </a>
    </div>

    <div class="card">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="fas fa-list"></i> Список всех дисциплин</h5>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Название дисциплины</th>
                                <th>Оценка</th>
                                <th>Преподаватель</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var discipline in Model)
                            {
                                <tr>
                                    <td>@discipline.Id</td>
                                    <td>@discipline.Name</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(discipline.Grade))
                                        {
                                            <span class="badge bg-success">@discipline.Grade</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (discipline.Teacher != null)
                                        {
                                            <span class="badge bg-info">@discipline.Teacher.FullName</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Не назначен</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Details", new { id = discipline.Id })" class="btn btn-sm btn-info" title="Подробности">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = discipline.Id })" class="btn btn-sm btn-warning" title="Редактировать">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a href="@Url.Action("Delete", new { id = discipline.Id })" class="btn btn-sm btn-danger" title="Удалить">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle"></i> Нет добавленных дисциплин
                </div>
            }
        </div>
    </div>
</div>