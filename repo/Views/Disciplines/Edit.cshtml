@model repo.Models.Discipline

@{
    ViewData["Title"] = "Редактирование дисциплины";
}

<div class="fade-in">
    <div class="d-flex justify-between align-center mb-3">
        <h2><i class="fas fa-edit"></i> Редактировать дисциплину</h2>
        <div>
            <a href="@Url.Action("AssignTeacher", new { id = Model.Id })" class="btn btn-info">
                <i class="fas fa-user-tie"></i> Назначить преподавателя
            </a>
            <a href="@Url.Action("Index")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Назад
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-warning">
                    <h5 class="mb-0"><i class="fas fa-pen"></i> Основная информация</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="form-group mb-3">
                            <label asp-for="Name" class="form-label">
                                <i class="fas fa-tag"></i> Название дисциплины <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Grade" class="form-label">
                                <i class="fas fa-star"></i> Оценка
                            </label>
                            <select asp-for="Grade" class="form-select">
                                <option value="">— Не указана —</option>
                                <option value="Отлично">Отлично (5)</option>
                                <option value="Хорошо">Хорошо (4)</option>
                                <option value="Удовлетворительно">Удовлетворительно (3)</option>
                                <option value="Неудовлетворительно">Неудовлетворительно (2)</option>
                                <option value="Зачет">Зачет</option>
                                <option value="Незачет">Незачет</option>
                            </select>
                            <span asp-validation-for="Grade" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">
                                <i class="fas fa-chalkboard-user"></i> Преподаватель
                            </label>
                            <select name="TeacherId" class="form-select">
                                <option value="">— Не назначен —</option>
                                @if (ViewBag.Teachers != null)
                                {
                                    foreach (var teacher in ViewBag.Teachers)
                                    {
                                        if (Model.Teacher != null && teacher.Id == Model.Teacher.Id)
                                        {
                                            <option value="@teacher.Id" selected>@teacher.FullName</option>
                                        }
                                        else
                                        {
                                            <option value="@teacher.Id">@teacher.FullName</option>
                                        }
                                    }
                                }
                            </select>
                        </div>

                        <div class="form-group mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Сохранить изменения
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Отмена
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-simple"></i> Статистика</h5>
                </div>
                <div class="card-body">
                    <div class="text-center">
                        <div class="stat-number" style="font-size: 2rem;">@(ViewBag.StudentsCount ?? 0)</div>
                        <div class="stat-label">студентов изучают</div>
                        <hr />
                        <div class="mt-2">
                            <i class="fas fa-calendar"></i> Создано: <strong>@DateTime.Now.ToString("dd.MM.yyyy")</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}