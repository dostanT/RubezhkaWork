@model repo.Models.Discipline

@{
    ViewData["Title"] = "Детали дисциплины";
}

<div class="fade-in">
    <div class="d-flex justify-between align-center mb-3">
        <h2><i class="fas fa-book-open"></i> Дисциплина: @Model.Name</h2>
        <div>
            <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning">
                <i class="fas fa-edit"></i> Редактировать
            </a>
            <a href="@Url.Action("Index")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Назад
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle"></i> Основная информация</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <th style="width: 40%">ID дисциплины:</th>
                            <td>@Model.Id</td>
                        </tr>
                        <tr>
                            <th>Название:</th>
                            <td><strong>@Model.Name</strong></td>
                        </tr>
                        <tr>
                            <th>Оценка:</th>
                            <td>
                                @if (!string.IsNullOrEmpty(Model.Grade))
                                {
                                    <span class="badge bg-success" style="font-size: 1rem;">@Model.Grade</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Не указана</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Преподаватель:</th>
                            <td>
                                @if (Model.Teacher != null)
                                {
                                    <div>
                                        <i class="fas fa-chalkboard-user"></i> <strong>@Model.Teacher.FullName</strong>
                                    </div>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Не назначен</span>
                                    <a href="@Url.Action("AssignTeacher", new { id = Model.Id })" class="btn btn-sm btn-primary ms-2">
                                        <i class="fas fa-user-plus"></i> Назначить
                                    </a>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-users"></i> Студенты, изучающие дисциплину</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.Students != null && ViewBag.Students.Count > 0)
                    {
                        <div class="alert alert-info">
                            <i class="fas fa-chart-line"></i> Всего студентов: <strong>@ViewBag.StudentsCount</strong>
                        </div>
                        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                            <table class="table table-sm table-striped">
                                <thead>
                                    <tr>
                                        <th>№ зачетки</th>
                                        <th>ФИО</th>
                                        <th>Группа</th>
                                        <th>Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var student in ViewBag.Students)
                                    {
                                        <tr>
                                            <td>@student.RecordBookNumber</td>
                                            <td>@student.LastName @student.FirstName @student.Patronymic</td>
                                            <td>@(student.Group?.Name ?? "—")</td>
                                            <td>
                                                <a href="@Url.Action("Details", "Students", new { id = student.RecordBookNumber })" 
                                                   class="btn btn-sm btn-info">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-secondary text-center">
                            <i class="fas fa-info-circle"></i> Нет студентов, изучающих эту дисциплину
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>