@model repo.Models.Discipline
@{
    ViewData["Title"] = "Детали дисциплины";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-info text-white">
            <h4><i class="fas fa-info-circle"></i> Детали дисциплины</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <table class="table table-bordered">
                        <tr>
                            <th style="width: 40%">ID:</th>
                            <td>@Model.Id</td>
                        </tr>
                        <tr>
                            <th>Название:</th>
                            <td>@Model.Name</td>
                        </tr>
                        <tr>
                            <th>Кредиты:</th>
                            <td>@Model.Credits</td>
                        </tr>
                        <tr>
                            <th>Преподаватель:</th>
                            <td>@(Model.Teacher?.FullName ?? "Не назначен")</td>
                        </tr>
                    </table>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-secondary text-white">
                            <h6 class="mb-0">Описание</h6>
                        </div>
                        <div class="card-body">
                            <p>@(string.IsNullOrEmpty(Model.Description) ? "Нет описания" : Model.Description)</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="fas fa-edit"></i> Редактировать
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Назад
                </a>
            </div>
        </div>
    </div>
</div>