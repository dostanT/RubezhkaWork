@model IEnumerable<repo.Models.Teacher>

@{
    ViewData["Title"] = "Преподаватели";
}

<div class="fade-in">
    <div class="d-flex justify-between align-center mb-3">
        <h2><i class="fas fa-chalkboard-user"></i> Преподаватели</h2>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-plus"></i> Добавить преподавателя
        </a>
    </div>

    <div class="card">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="fas fa-list"></i> Список преподавателей</h5>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Фамилия</th>
                                <th>Имя</th>
                                <th>Отчество</th>
                                <th>Дисциплин</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var teacher in Model)
                            {
                                <tr>
                                    <td>@teacher.Id</td>
                                    <td>@teacher.LastName</td>
                                    <td>@teacher.FirstName</td>
                                    <td>@teacher.Patronymic</td>
                                    <td>
                                        <span class="badge bg-info">@(teacher.Disciplines?.Count ?? 0)</span>
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Details", new { id = teacher.Id })" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = teacher.Id })" class="btn btn-sm btn-warning">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a href="@Url.Action("Delete", new { id = teacher.Id })" class="btn btn-sm btn-danger">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle"></i> Преподаватели не найдены
                </div>
            }
        </div>
    </div>
</div>