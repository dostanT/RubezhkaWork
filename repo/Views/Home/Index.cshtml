@{
    ViewData["Title"] = "Главная панель";
}

<div class="container py-4">
    <h2 class="mb-4">Добро пожаловать в систему управления университетом</h2>

    @* Карточки быстрого доступа к разделам *@
    <div class="row g-4 mb-5">
        <div class="col-md-3 col-sm-6">
            <a href="@Url.Action("Index", "Students")" class="text-decoration-none">
                <div class="card text-white bg-primary h-100 shadow-sm">
                    <div class="card-body text-center">
                        <i class="fas fa-user-graduate fa-3x mb-3"></i>
                        <h5 class="card-title">Студенты</h5>
                        <p class="card-text display-6">@ViewBag.TotalStudents</p>
                        <span>Управление студентами →</span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-sm-6">
            <a href="@Url.Action("Index", "Groups")" class="text-decoration-none">
                <div class="card text-white bg-success h-100 shadow-sm">
                    <div class="card-body text-center">
                        <i class="fas fa-users fa-3x mb-3"></i>
                        <h5 class="card-title">Группы</h5>
                        <p class="card-text display-6">@ViewBag.TotalGroups</p>
                        <span>Управление группами →</span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-sm-6">
            <a href="@Url.Action("Index", "Departments")" class="text-decoration-none">
                <div class="card text-white bg-info h-100 shadow-sm">
                    <div class="card-body text-center">
                        <i class="fas fa-building fa-3x mb-3"></i>
                        <h5 class="card-title">Кафедры</h5>
                        <p class="card-text display-6">@ViewBag.TotalDepartments</p>
                        <span>Управление кафедрами →</span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-sm-6">
            <a href="@Url.Action("Index", "Teachers")" class="text-decoration-none">
                <div class="card text-white bg-warning h-100 shadow-sm">
                    <div class="card-body text-center">
                        <i class="fas fa-chalkboard-user fa-3x mb-3"></i>
                        <h5 class="card-title">Преподаватели</h5>
                        <p class="card-text display-6">@ViewBag.TotalTeachers</p>
                        <span>Управление преподавателями →</span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-sm-6">
            <a href="@Url.Action("Index", "Disciplines")" class="text-decoration-none">
                <div class="card text-white bg-danger h-100 shadow-sm">
                    <div class="card-body text-center">
                        <i class="fas fa-book fa-3x mb-3"></i>
                        <h5 class="card-title">Дисциплины</h5>
                        <p class="card-text display-6">@ViewBag.TotalDisciplines</p>
                        <span>Управление дисциплинами →</span>
                    </div>
                </div>
            </a>
        </div>
    </div>

    @* Статистика и графики *@
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5><i class="fas fa-chart-pie me-2"></i>Распределение по типам обучения</h5>
                </div>
                <div class="card-body">
                    <canvas id="studentTypeChart" height="250"></canvas>
                    <div class="mt-3 d-flex justify-content-around">
                        <span><span class="badge bg-primary">Очное</span> @ViewBag.FullTimeCount чел.</span>
                        <span><span class="badge bg-info">Заочное</span> @ViewBag.PartTimeCount чел.</span>
                        <span><span class="badge bg-success">Целевое</span> @ViewBag.TargetCount чел.</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5><i class="fas fa-chart-bar me-2"></i>Количество студентов по группам</h5>
                </div>
                <div class="card-body">
                    <canvas id="groupsChart" height="250"></canvas>
                </div>
            </div>
        </div>
    </div>

    @* Топ студентов *@
    <div class="card shadow-sm mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5><i class="fas fa-trophy me-2"></i>Топ-5 студентов по успеваемости</h5>
            <a href="@Url.Action("Index", "Students")" class="btn btn-sm btn-outline-primary">Все студенты →</a>
        </div>
        <div class="card-body">
            @if (ViewBag.TopStudents != null && ViewBag.TopStudents.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>ФИО</th>
                                <th>Группа</th>
                                <th>Средний балл</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int counter = 1;
                                foreach (var student in ViewBag.TopStudents)
                                {
                                    <tr>
                                        <td>
                                            @if (counter == 1)
                                            {
                                                <span class="badge bg-warning">🥇 @counter</span>
                                            }
                                            else if (counter == 2)
                                            {
                                                <span class="badge bg-secondary">🥈 @counter</span>
                                            }
                                            else if (counter == 3)
                                            {
                                                <span class="badge bg-danger">🥉 @counter</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">@counter</span>
                                            }
                                        </td>
                                        <td>@student.LastName @student.FirstName @student.Patronymic</td>
                                        <td>@(student.Group?.Name ?? "—")</td>
                                        <td>
                                            @if (student.AverageScore > 0)
                                            {
                                                <span class="badge bg-success">@student.AverageScore.ToString("F2")</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">—</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Details", "Students", new { id = student.RecordBookNumber })" class="btn btn-sm btn-outline-info">
                                                <i class="fas fa-eye"></i> Подробнее
                                            </a>
                                        </td>
                                    </tr>
                                    counter++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle me-2"></i>Нет данных о студентах
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // График типов обучения
        const ctx1 = document.getElementById('studentTypeChart').getContext('2d');
        new Chart(ctx1, {
            type: 'doughnut',
            data: {
                labels: ['Очное обучение', 'Заочное обучение', 'Целевое обучение'],
                datasets: [{
                    data: [@ViewBag.FullTimeCount, @ViewBag.PartTimeCount, @ViewBag.TargetCount],
                    backgroundColor: ['#0d6efd', '#0dcaf0', '#198754'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });

        // График групп
        const ctx2 = document.getElementById('groupsChart').getContext('2d');
        const groupsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.GroupsStat));
        
        new Chart(ctx2, {
            type: 'bar',
            data: {
                labels: Object.keys(groupsData),
                datasets: [{
                    label: 'Количество студентов',
                    data: Object.values(groupsData),
                    backgroundColor: '#198754',
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1
                        }
                    }
                },
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });
    </script>
}