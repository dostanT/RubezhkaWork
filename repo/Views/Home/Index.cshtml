@{
    ViewData["Title"] = "Панель управления";
}

<div class="fade-in">
    <div class="stats-grid mb-4">
        <div class="stat-card">
            <div class="stat-icon bg-primary">
                <i class="fas fa-user-graduate"></i>
            </div>
            <div class="stat-number">@ViewBag.TotalStudents</div>
            <div class="stat-label">Всего студентов</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon bg-success">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-number">@ViewBag.TotalGroups</div>
            <div class="stat-label">Групп</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon bg-info">
                <i class="fas fa-building"></i>
            </div>
            <div class="stat-number">@ViewBag.TotalDepartments</div>
            <div class="stat-label">Кафедр</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon bg-warning">
                <i class="fas fa-book"></i>
            </div>
            <div class="stat-number">@ViewBag.TotalDisciplines</div>
            <div class="stat-label">Дисциплин</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon bg-danger">
                <i class="fas fa-chalkboard-user"></i>
            </div>
            <div class="stat-number">@ViewBag.TotalTeachers</div>
            <div class="stat-label">Преподавателей</div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-pie"></i> Распределение по типам обучения</h5>
                </div>
                <div class="card-body">
                    <canvas id="studentTypeChart" height="250"></canvas>
                    <div class="mt-3">
                        <div class="d-flex justify-between">
                            <span><span class="badge bg-primary">Очное</span> @ViewBag.FullTimeCount чел.</span>
                            <span><span class="badge bg-info">Заочное</span> @ViewBag.PartTimeCount чел.</span>
                            <span><span class="badge bg-success">Целевое</span> @ViewBag.TargetCount чел.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-bar"></i> Распределение по группам</h5>
                </div>
                <div class="card-body">
                    <canvas id="groupsChart" height="250"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12 mb-4">
            <div class="card">
                <div class="card-header bg-info text-white d-flex justify-between align-center">
                    <h5 class="mb-0"><i class="fas fa-trophy"></i> Топ-5 студентов по успеваемости</h5>
                    <a href="@Url.Action("Index", "Students")" class="btn btn-sm btn-light">Все студенты →</a>
                </div>
                <div class="card-body">
                    @if (ViewBag.TopStudents != null && ViewBag.TopStudents.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>№</th>
                                        <th>ФИО</th>
                                        <th>Группа</th>
                                        <th>Кафедра</th>
                                        <th>Средний балл</th>
                                        <th>Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int counter = 1;
                                        foreach (var student in ViewBag.TopStudents)
                                        {
                                            <tr>
                                                <td>
                                                    @if (counter == 1)
                                                    {
                                                        <span class="badge bg-warning">🥇 @counter</span>
                                                    }
                                                    else if (counter == 2)
                                                    {
                                                        <span class="badge bg-secondary">🥈 @counter</span>
                                                    }
                                                    else if (counter == 3)
                                                    {
                                                        <span class="badge bg-danger">🥉 @counter</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-info">@counter</span>
                                                    }
                                                </td>
                                                <td>@student.LastName @student.FirstName</td>
                                                <td>@(student.Group?.Name ?? "—")</td>
                                                <td>@(student.Department?.Name ?? "—")</td>
                                                <td>
                                                    @if (student.AverageScore > 0)
                                                    {
                                                        <span class="badge bg-success">@student.AverageScore.ToString("F2")</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">—</span>
                                                    }
                                                </td>
                                                <td>
                                                    <a href="@Url.Action("Details", "Students", new { id = student.RecordBookNumber })" 
                                                       class="btn btn-sm btn-info">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                            counter++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <i class="fas fa-info-circle"></i> Нет данных о студентах
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card">
                <div class="card-header bg-warning">
                    <h5 class="mb-0"><i class="fas fa-rocket"></i> Быстрые действия</h5>
                </div>
                <div class="card-body">
                    <div class="btn-group w-100" style="flex-direction: column; gap: 10px;">
                        <a href="@Url.Action("Create", "Students")" class="btn btn-primary">
                            <i class="fas fa-user-plus"></i> Добавить студента
                        </a>
                        <a href="@Url.Action("Create", "Groups")" class="btn btn-success">
                            <i class="fas fa-users"></i> Создать группу
                        </a>
                        <a href="@Url.Action("Create", "Disciplines")" class="btn btn-info">
                            <i class="fas fa-book"></i> Добавить дисциплину
                        </a>
                        <a href="@Url.Action("Create", "Teachers")" class="btn btn-warning">
                            <i class="fas fa-chalkboard-user"></i> Добавить преподавателя
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fas fa-filter"></i> Фильтрация студентов</h5>
                </div>
                <div class="card-body">
                    <form action="@Url.Action("Filter", "Students")" method="get">
                        <div class="form-group mb-3">
                            <label class="form-label">По группе:</label>
                            <select name="groupName" class="form-select">
                                <option value="">Выберите группу...</option>
                                @foreach (var group in ViewBag.GroupsStat?.Keys ?? new List<string>())
                                {
                                    <option value="@group">@group (@ViewBag.GroupsStat[group])</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-danger w-100">
                            <i class="fas fa-search"></i> Применить фильтр
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-line"></i> Статистика системы</h5>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <small class="text-muted">Заполненность групп:</small>
                        <div class="progress mt-1">
                            @{
                                double avgStudentsPerGroup = ViewBag.TotalGroups > 0 ? (double)ViewBag.TotalStudents / ViewBag.TotalGroups : 0;
                                double fillPercentage = (avgStudentsPerGroup / 30) * 100;
                                fillPercentage = fillPercentage > 100 ? 100 : fillPercentage;
                            }
                            <div class="progress-bar bg-success" style="width: @fillPercentage%">
                                @avgStudentsPerGroup.ToString("F1") студ./группу
                            </div>
                        </div>
                    </div>
                    <hr />
                    <div>
                        <i class="fas fa-calendar"></i> Текущий учебный год: <strong>2024-2025</strong>
                    </div>
                    <div class="mt-2">
                        <i class="fas fa-clock"></i> Последнее обновление: <strong>@DateTime.Now.ToString("dd.MM.yyyy HH:mm")</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // График типов обучения
        const ctx1 = document.getElementById('studentTypeChart').getContext('2d');
        new Chart(ctx1, {
            type: 'doughnut',
            data: {
                labels: ['Очное обучение', 'Заочное обучение', 'Целевое обучение'],
                datasets: [{
                    data: [@ViewBag.FullTimeCount, @ViewBag.PartTimeCount, @ViewBag.TargetCount],
                    backgroundColor: ['#3498db', '#17a2b8', '#28a745'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });

        // График групп
        const ctx2 = document.getElementById('groupsChart').getContext('2d');
        const groupsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.GroupsStat));
        
        new Chart(ctx2, {
            type: 'bar',
            data: {
                labels: Object.keys(groupsData),
                datasets: [{
                    label: 'Количество студентов',
                    data: Object.values(groupsData),
                    backgroundColor: '#28a745',
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1
                        }
                    }
                },
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });
    </script>
}