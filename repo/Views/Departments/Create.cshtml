@model repo.Models.Department
@{
    ViewData["Title"] = "Добавление кафедры";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-success text-white">
            <h4><i class="fas fa-plus-circle"></i> Добавление кафедры</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="Name" class="form-label">Название кафедры *</label>
                    <input asp-for="Name" class="form-control" placeholder="Пример: Кафедра информационных технологий" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="HeadOfDepartment" class="form-label">Заведующий кафедрой *</label>
                    <input asp-for="HeadOfDepartment" class="form-control" placeholder="Иванов Иван Иванович" />
                    <span asp-validation-for="HeadOfDepartment" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Phone" class="form-label">Телефон *</label>
                            <input asp-for="Phone" class="form-control" placeholder="+7 (XXX) XXX-XX-XX" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Email" class="form-label">Email *</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="department@university.ru" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Сохранить
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Отмена
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>