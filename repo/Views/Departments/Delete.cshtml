@model repo.Models.Department
@{
    ViewData["Title"] = "Удаление кафедры";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-danger text-white">
            <h4><i class="fas fa-exclamation-triangle"></i> Удаление кафедры</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <strong>Внимание!</strong> Вы действительно хотите удалить кафедру?
            </div>

            <table class="table table-bordered">
                <tr>
                    <th style="width: 30%">ID:</th>
                    <td>@Model.Id</td>
                </tr>
                <tr>
                    <th>Название кафедры:</th>
                    <td>@Model.Name</td>
                </tr>
                <tr>
                    <th>Заведующий:</th>
                    <td>@Model.HeadOfDepartment</td>
                </tr>
                <tr>
                    <th>Телефон:</th>
                    <td>@Model.Phone</td>
                </tr>
                <tr>
                    <th>Email:</th>
                    <td>@Model.Email</td>
                </tr>
            </table>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Удалить
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Отмена
                </a>
            </form>
        </div>
    </div>
</div>