@model List<Department>

@{
    ViewData["Title"] = "Кафедры";
}

<div class="fade-in">
    <div class="d-flex justify-between align-center mb-3">
        <h2><i class="fas fa-building"></i> Управление кафедрами</h2>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-plus"></i> Добавить кафедру
        </a>
    </div>

    <div class="card">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="fas fa-list"></i> Список кафедр</h5>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Название кафедры</th>
                                <th>Заведующий кафедрой</th>
                                <th>Телефон</th>
                                <th>Email</th>
                                <th>Студентов</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var department in Model)
                            {
                                <tr>
                                    <td>@department.Id</td>
                                    <td>@department.Name</td>
                                    <td>
                                        <span class="badge bg-info">@(department.Students?.Count ?? 0)</span>
                                    </td>
                                    <td>
                                        <div class="btn-group">
                                            <a href="@Url.Action("Details", new { id = department.Id })" 
                                               class="btn btn-sm btn-info" title="Подробнее">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="@Url.Action("Edit", new { id = department.Id })" 
                                               class="btn btn-sm btn-warning" title="Редактировать">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="@Url.Action("Delete", new { id = department.Id })" 
                                               class="btn btn-sm btn-danger" title="Удалить">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle"></i> Кафедры отсутствуют. 
                    <a href="@Url.Action("Create")" class="alert-link">Добавить первую кафедру</a>
                </div>
            }
        </div>
    </div>
</div>