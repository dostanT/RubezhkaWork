@model Department

@{
    ViewData["Title"] = $"Редактирование: {Model.Name}";
}

<div class="fade-in">
    <div class="d-flex justify-between align-center mb-3">
        <h2><i class="fas fa-edit"></i> Редактирование кафедры</h2>
        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Назад к списку
        </a>
    </div>

    <div class="card">
        <div class="card-header bg-warning">
            <h5 class="mb-0"><i class="fas fa-building"></i> Кафедра: @Model.Name</h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Name" class="form-label">
                                <i class="fas fa-tag"></i> Название кафедры <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                @if (ViewBag.StudentsCount > 0)
                {
                    <div class="alert alert-info mt-3">
                        <i class="fas fa-info-circle"></i> 
                        На кафедре обучается <strong>@ViewBag.StudentsCount</strong> студентов.
                        Изменение названия кафедры автоматически обновится у всех студентов.
                    </div>
                }

                <div class="form-group mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Сохранить изменения
                    </button>
                    <a href="@Url.Action("Details", new { id = Model.Id })" class="btn btn-info">
                        <i class="fas fa-eye"></i> Просмотр
                    </a>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Отмена
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}