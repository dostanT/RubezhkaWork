@model repo.Models.Auth

@{
    ViewData["Title"] = "Регистрация";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow border-success">
            <div class="card-header bg-success text-white text-center">
                <h4>Создать аккаунт</h4>
            </div>
            <div class="card-body">
                <form asp-action="SignUp" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group mb-3">
                        <label asp-for="login" class="form-label">Придумайте логин</label>
                        <input asp-for="login" class="form-control" placeholder="Минимум 3 символа" required />
                        <span asp-validation-for="login" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="password" class="form-label">Придумайте пароль</label>
                        <input asp-for="password" type="password" class="form-control" placeholder="Минимум 6 символов" required />
                        <span asp-validation-for="password" class="text-danger"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-success">Зарегистрироваться</button>
                    </div>
                </form>
            </div>
            <div class="card-footer text-center">
                <small>Уже есть аккаунт? <a asp-action="SignIn">Войти</a></small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}