@model repo.Models.Auth

@{
    ViewData["Title"] = "Вход в систему";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-header bg-primary text-white text-center">
                <h4>Авторизация</h4>
            </div>
            <div class="card-body">
                <form asp-action="SignIn" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group mb-3">
                        <label asp-for="login" class="form-label">Логин</label>
                        <input asp-for="login" class="form-control" placeholder="Введите логин" required />
                        <span asp-validation-for="login" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="password" class="form-label">Пароль</label>
                        <input asp-for="password" type="password" class="form-control" placeholder="Введите пароль" required />
                        <span asp-validation-for="password" class="text-danger"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Войти</button>
                    </div>
                </form>
            </div>
            <div class="card-footer text-center">
                <small>Нет аккаунта? <a asp-action="SignUp">Зарегистрироваться</a></small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}